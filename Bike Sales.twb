              <calculation class='tableau' formula='IF [Date - Year]= [Parameters].[Parameter 1] THEN [Profit] END' />
            </column>
            <column caption='Last Year Profit' datatype='integer' name='[Calculation_1338162717802501]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF  [Date - Year]=DATEADD(&apos;year&apos;, -1, [Parameters].[Parameter 1])THEN [Profit] END' />
